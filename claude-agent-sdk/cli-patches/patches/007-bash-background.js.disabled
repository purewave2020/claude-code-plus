/**
 * run_to_background 补丁 v3
 *
 * 添加统一的 run_to_background 控制命令，自动判断任务类型（Bash 或 Agent）。
 *
 * 设计原则：
 * - 最小侵入性：所有逻辑代码抽取到全局对象 global.__claudePlusBash
 * - 只在原有代码中注入最少的方法调用
 * - 统一接口：调用者无需区分 Bash 和 Agent
 *
 * 实现原理：
 * - Step 1: 注入全局工具对象 global.__claudePlusBash
 * - Step 2: 修改 se5 调用，传入 toolUseId
 * - Step 3: 在 se5 函数中，创建 shellCommand 后注册到全局 Map
 * - Step 4: 在控制请求处理中添加 run_to_background 统一命令
 *
 * 支持的控制命令：
 * - run_to_background: { task_id?: string }
 *   - task_id 传入时: 后台指定任务（自动判断是 Bash 还是 Agent）
 *   - task_id 不传时: 后台所有前台任务（等同于 Ctrl+B）
 * - bash_run_to_background: { task_id: string }（向后兼容）
 *   - task_id 是 tool_use_id，用于标识特定的 Bash 命令
 */

module.exports = {
  id: 'bash_run_to_background',
  description: 'Add bash_run_to_background control command for Bash background execution',
  priority: 101,
  required: false,
  disabled: false,

  apply(ast, t, traverse, context) {
    const details = [];
    let step1Done = false;  // 注入全局对象
    let step2Done = false;  // 修改 se5 调用
    let step3Done = false;  // 在 se5 中注册
    let step4Done = false;  // 添加控制命令

    let h09FuncName = null;
    let se5FuncName = null;

    // ========================================
    // Step 0: 找到关键函数名
    // ========================================
    
    traverse(ast, {
      FunctionDeclaration(path) {
        // 找 H09: function H09(A, Q) { let Y = HxA("local_bash"); ... }
        if (!h09FuncName) {
          let hasLocalBashCall = false;
          path.traverse({
            CallExpression(callPath) {
              const args = callPath.node.arguments;
              if (args.length === 1 && t.isStringLiteral(args[0]) && args[0].value === "local_bash") {
                hasLocalBashCall = true;
              }
            }
          });
          if (hasLocalBashCall && path.node.id) {
            h09FuncName = path.node.id.name;
          }
        }
        
        // 找 se5: async function* se5({input, ...})
        if (!se5FuncName && path.node.async && path.node.generator) {
          const params = path.node.params;
          if (params.length === 1 && t.isObjectPattern(params[0])) {
            let hasInput = false;
            let hasSetAppState = false;
            for (const prop of params[0].properties) {
              if (t.isObjectProperty(prop) && t.isIdentifier(prop.key)) {
                if (prop.key.name === 'input') hasInput = true;
                if (prop.key.name === 'setAppState') hasSetAppState = true;
              }
            }
            if (hasInput && hasSetAppState && path.node.id) {
              se5FuncName = path.node.id.name;
            }
          }
        }
      }
    });

    if (!h09FuncName) {
      return { success: false, reason: '未找到 H09 函数' };
    }
    if (!se5FuncName) {
      return { success: false, reason: '未找到 se5 函数' };
    }
    
    details.push(`找到 H09 函数: "${h09FuncName}"`);
    details.push(`找到 se5 函数: "${se5FuncName}"`);

    // ========================================
    // Step 1: 在程序开头注入全局工具对象
    // ========================================
    const globalObjectCode = `
(function() {
  if (global.__claudePlusBash) return;
  global.__claudePlusBash = {
    running: new Map(),
    register: function(toolUseId, shellCommand, setAppState, command, description) {
      if (!toolUseId || !shellCommand) return;
      this.running.set(toolUseId, { shellCommand, setAppState, command, description, startTime: Date.now() });
    },
    unregister: function(toolUseId) {
      if (toolUseId) this.running.delete(toolUseId);
    },
    background: function(toolUseId, H09Func) {
      var entry = this.running.get(toolUseId);
      if (!entry) return { success: false, error: "Bash not found: " + toolUseId };
      if (!entry.shellCommand) return { success: false, error: "Shell command not available" };
      try {
        var result = H09Func({ command: entry.command, description: entry.description || entry.command, shellCommand: entry.shellCommand }, entry.setAppState);
        entry.shellCommand.status = "backgrounded";
        this.running.delete(toolUseId);
        return { success: true, taskId: result.taskId, command: entry.command };
      } catch (e) {
        return { success: false, error: e.message || String(e) };
      }
    },
    getRunning: function(minDurationMs) {
      var result = [], now = Date.now();
      this.running.forEach(function(entry, toolUseId) {
        var duration = now - entry.startTime;
        if (!minDurationMs || duration >= minDurationMs) result.push({ toolUseId, command: entry.command, duration });
      });
      return result;
    }
  };
})();
`;

    const parser = require('@babel/parser');
    const globalObjectAst = parser.parse(globalObjectCode, { sourceType: 'script' });
    ast.program.body.unshift(...globalObjectAst.program.body);
    step1Done = true;
    details.push('注入全局工具对象 global.__claudePlusBash');

    // ========================================
    // Step 2: 修改 Bash call 方法中的 se5 调用，传入 toolUseId
    // ========================================
    traverse(ast, {
      ObjectMethod(path) {
        if (step2Done) return;
        if (!path.node.async || !t.isIdentifier(path.node.key) || path.node.key.name !== 'call') return;
        
        const params = path.node.params;
        if (params.length < 5) return;
        
        // 检查是否有 _simulatedSedEdit（Bash 特征）
        let hasSimulatedSedEdit = false;
        path.traverse({
          MemberExpression(memPath) {
            if (t.isIdentifier(memPath.node.property) && memPath.node.property.name === '_simulatedSedEdit') {
              hasSimulatedSedEdit = true;
            }
          }
        });
        if (!hasSimulatedSedEdit) return;

        const toolUseIdParam = params[2];  // B
        if (!t.isIdentifier(toolUseIdParam)) return;
        const toolUseIdName = toolUseIdParam.name;

        // 找到 se5 调用并修改
        path.traverse({
          CallExpression(callPath) {
            if (step2Done) return;
            const callee = callPath.node.callee;
            if (!t.isIdentifier(callee) || callee.name !== se5FuncName) return;
            
            const args = callPath.node.arguments;
            if (args.length !== 1 || !t.isObjectExpression(args[0])) return;
            
            // 添加 __toolUseId 属性
            args[0].properties.push(
              t.objectProperty(
                t.identifier('__toolUseId'),
                t.identifier(toolUseIdName)
              )
            );
            
            step2Done = true;
            details.push(`修改 ${se5FuncName} 调用，添加 __toolUseId 参数`);
          }
        });
      }
    });

    // ========================================
    // Step 3: 修改 se5 函数，解构 __toolUseId 并在创建 shellCommand 后注册
    // ========================================
    traverse(ast, {
      FunctionDeclaration(path) {
        if (step3Done) return;
        if (!path.node.id || path.node.id.name !== se5FuncName) return;
        if (!path.node.async || !path.node.generator) return;
        
        const params = path.node.params;
        if (params.length !== 1 || !t.isObjectPattern(params[0])) return;
        
        // 添加 __toolUseId 到解构参数
        params[0].properties.push(
          t.objectProperty(
            t.identifier('__toolUseId'),
            t.identifier('__toolUseId'),
            false,
            true  // shorthand
          )
        );
        
        // 找到 shellCommand 的赋值（await Z51 调用）
        // 特征：let z = await Z51(...)
        path.traverse({
          VariableDeclaration(varPath) {
            if (step3Done) return;
            
            for (const decl of varPath.node.declarations) {
              if (!t.isIdentifier(decl.id)) continue;
              if (!t.isAwaitExpression(decl.init)) continue;
              
              const awaitArg = decl.init.argument;
              if (!t.isCallExpression(awaitArg)) continue;
              if (!t.isIdentifier(awaitArg.callee)) continue;
              
              // 检查是否是 Z51 类似的函数（创建 shell command）
              // 通过检查参数来确认：第一个参数是 command 变量
              const args = awaitArg.arguments;
              if (args.length < 3) continue;
              
              // 假设这就是 shellCommand 赋值
              const shellCommandVar = decl.id.name;
              
              // 在此语句后注入注册调用
              const registerCode = `
                if (global.__claudePlusBash && __toolUseId && ${shellCommandVar}) {
                  global.__claudePlusBash.register(__toolUseId, ${shellCommandVar}, setAppState, input.command, input.description);
                }
              `;
              
              const registerAst = parser.parse(registerCode, { sourceType: 'script' });
              
              // 找到包含此 VariableDeclaration 的 index
              const parentBody = varPath.parentPath;
              if (!t.isBlockStatement(parentBody.node)) continue;
              
              const stmtIndex = parentBody.node.body.indexOf(varPath.node);
              if (stmtIndex === -1) continue;
              
              // 在后面插入
              parentBody.node.body.splice(stmtIndex + 1, 0, ...registerAst.program.body);
              
              step3Done = true;
              details.push(`在 ${se5FuncName} 中注入 shellCommand 注册 (变量: ${shellCommandVar})`);
              return;
            }
          }
        });
        
        // 在函数末尾添加 finally 清理（如果有 try）
        if (step3Done) {
          const body = path.node.body;
          if (t.isBlockStatement(body)) {
            // 在函数结尾添加清理（通过 try/finally 或直接添加）
            const cleanupCode = `
              if (global.__claudePlusBash && __toolUseId) {
                global.__claudePlusBash.unregister(__toolUseId);
              }
            `;
            // 清理会在正常返回时自动通过 Map 删除，暂不添加额外逻辑
          }
        }
      }
    });

    // ========================================
    // Step 4: 添加控制命令处理
    // ========================================
    traverse(ast, {
      IfStatement(path) {
        if (step4Done) return;
        
        const test = path.node.test;
        if (!t.isBinaryExpression(test) || test.operator !== '===') return;
        
        const left = test.left;
        if (!t.isMemberExpression(left)) return;
        if (!t.isIdentifier(left.property) || left.property.name !== 'subtype') return;
        
        const obj = left.object;
        if (!t.isMemberExpression(obj)) return;
        if (!t.isIdentifier(obj.property) || obj.property.name !== 'request') return;
        
        if (!t.isStringLiteral(test.right) || test.right.value !== 'interrupt') return;
        
        const requestVar = obj.object;
        if (!t.isIdentifier(requestVar)) return;
        
        // 找响应函数名
        let responderName = 's';
        if (t.isBlockStatement(path.node.consequent)) {
          for (const stmt of path.node.consequent.body) {
            if (t.isExpressionStatement(stmt) && t.isCallExpression(stmt.expression)) {
              if (t.isIdentifier(stmt.expression.callee)) {
                responderName = stmt.expression.callee.name;
                break;
              }
            }
          }
        }
        
        // 统一的 run_to_background 命令
        // - 传入 task_id: 先尝试作为 Bash 后台，如果不是 Bash 则返回 is_bash=false
        // - 不传 task_id: 后台所有 Bash，返回数量
        const unifiedBackgroundCode = `
          var __taskId = ${requestVar.name}.request.task_id;
          var __result = { success: false, error: "Global object not initialized" };
          if (global.__claudePlusBash) {
            if (__taskId) {
              // 尝试后台指定任务（先检查是否是 Bash）
              if (global.__claudePlusBash.running.has(__taskId)) {
                __result = global.__claudePlusBash.background(__taskId, ${h09FuncName});
                __result.is_bash = true;
              } else {
                // 不是 Bash，告诉 SDK 去尝试 Agent
                __result = { success: true, is_bash: false, task_id: __taskId };
              }
            } else {
              // 后台所有 Bash
              var __bashCount = 0;
              var __bashIds = [];
              global.__claudePlusBash.running.forEach(function(entry, id) {
                var r = global.__claudePlusBash.background(id, ${h09FuncName});
                if (r.success) { __bashCount++; __bashIds.push(id); }
              });
              __result = { success: true, bash_count: __bashCount, backgrounded_bash_ids: __bashIds };
            }
          }
          ${responderName}({
            ...${requestVar.name},
            response: {
              subtype: __result.success ? "success" : "error",
              request_id: ${requestVar.name}.request_id,
              response: __result.success ? __result : undefined,
              error: __result.success ? undefined : __result.error
            }
          });
        `;
        
        const unifiedBackgroundAst = parser.parse(unifiedBackgroundCode, { sourceType: 'script' });
        const unifiedBackgroundBlock = t.blockStatement(unifiedBackgroundAst.program.body);
        
        const unifiedBackgroundCondition = t.binaryExpression(
          '===',
          t.memberExpression(
            t.memberExpression(t.cloneNode(requestVar), t.identifier('request')),
            t.identifier('subtype')
          ),
          t.stringLiteral('run_to_background')
        );
        
        // 向后兼容的 bash_run_to_background 命令
        const bashBackgroundCode = `
          var __taskId = ${requestVar.name}.request.task_id;
          var __result = { success: false, error: "Global object not initialized" };
          if (global.__claudePlusBash && __taskId) {
            __result = global.__claudePlusBash.background(__taskId, ${h09FuncName});
          } else if (!__taskId) {
            __result = { success: false, error: "task_id is required" };
          }
          ${responderName}({
            ...${requestVar.name},
            response: {
              subtype: __result.success ? "success" : "error",
              request_id: ${requestVar.name}.request_id,
              response: __result.success ? { task_id: __result.taskId, command: __result.command } : undefined,
              error: __result.success ? undefined : __result.error
            }
          });
        `;
        
        const bashBackgroundAst = parser.parse(bashBackgroundCode, { sourceType: 'script' });
        const bashBackgroundBlock = t.blockStatement(bashBackgroundAst.program.body);
        
        const bashBackgroundCondition = t.binaryExpression(
          '===',
          t.memberExpression(
            t.memberExpression(t.cloneNode(requestVar), t.identifier('request')),
            t.identifier('subtype')
          ),
          t.stringLiteral('bash_run_to_background')
        );
        
        // 构建 if-else 链: run_to_background -> bash_run_to_background -> 原有逻辑
        const bashBackgroundIf = t.ifStatement(
          bashBackgroundCondition,
          bashBackgroundBlock,
          path.node  // 原有的 interrupt 等处理
        );
        
        const unifiedBackgroundIf = t.ifStatement(
          unifiedBackgroundCondition,
          unifiedBackgroundBlock,
          bashBackgroundIf  // else 是 bash_run_to_background
        );
        
        path.replaceWith(unifiedBackgroundIf);
        step4Done = true;
        details.push(`添加 run_to_background 统一命令和 bash_run_to_background 兼容命令`);
        path.stop();
      }
    });

    // ========================================
    // 返回结果
    // ========================================
    const allStepsDone = step1Done && step2Done && step3Done && step4Done;
    
    if (allStepsDone) {
      return { success: true, details };
    }
    
    // 部分成功也可以接受，记录警告
    if (step1Done && step4Done) {
      details.push(`警告: 部分注入未完成 (step2=${step2Done}, step3=${step3Done})，可能需要手动验证`);
      return { success: true, details };
    }

    return {
      success: false,
      reason: `补丁应用失败: step1=${step1Done}, step2=${step2Done}, step3=${step3Done}, step4=${step4Done}`,
      details
    };
  }
};
